# Copy to .env and fill in your Firebase Web SDK config from
# https://console.firebase.google.com → Project settings → Your apps → Web app.
# The API key is safe to ship in client code (see DESIGN_DECISIONS §7).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Leave blank in dev — Vite proxies /api to localhost:8000.
# In production, set to the deployed API origin (e.g. https://api.example.com).
VITE_API_BASE_URL=

# EmailJS config — sign up free at https://emailjs.com and create a
# Gmail-backed service + a template (see DESIGN_DECISIONS.md §8).
# These are public client identifiers, NOT secrets — EmailJS rate-limits
# by origin via Authorized Domains in their dashboard.
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
